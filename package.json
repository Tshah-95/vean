{
  "name": "vean",
  "version": "0.0.0",
  "description": "The agent-native video editing core — a typed document, edit algebra, and diagnostics layer (a language server for video) on top of MLT.",
  "type": "module",
  "license": "AGPL-3.0-only",
  "private": true,
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "overrides": {
    "@wdio/native-utils": "2.5.0"
  },
  "resolutions": {
    "@wdio/native-utils": "2.5.0"
  },
  "bin": {
    "vean": "src/cli.ts",
    "vean-lsp": "src/bridge/lsp/server.ts",
    "vean-mcp": "src/bridge/mcp/server.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "doctor": "bun src/cli.ts doctor",
    "app:doctor": "bun scripts/app-doctor.ts",
    "app:build": "cd app && bun run tauri:build",
    "remotion:install": "cd remotion && bun install",
    "remotion:studio": "cd remotion && bun run studio",
    "viewer:install": "cd viewer && bun install",
    "viewer:dev": "cd viewer && bun run dev",
    "viewer:typecheck": "bun run --cwd viewer typecheck",
    "viewer:lint": "bun run --cwd viewer lint",
    "viewer:build": "cd viewer && bun run build",
    "remotion:typecheck": "bun run --cwd remotion typecheck",
    "remotion:lint": "bun run --cwd remotion lint",
    "rust:fmt": "rustup run 1.95.0 cargo fmt --manifest-path app/src-tauri/Cargo.toml --all -- --check",
    "rust:check": "TAURI_CONFIG='{\"bundle\":{\"externalBin\":[],\"resources\":[]}}' rustup run 1.95.0 cargo check --locked --manifest-path app/src-tauri/Cargo.toml --all-targets --all-features",
    "rust:clippy": "TAURI_CONFIG='{\"bundle\":{\"externalBin\":[],\"resources\":[]}}' rustup run 1.95.0 cargo clippy --locked --manifest-path app/src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "rust:test": "TAURI_CONFIG='{\"bundle\":{\"externalBin\":[],\"resources\":[]}}' rustup run 1.95.0 cargo test --locked --manifest-path app/src-tauri/Cargo.toml --all-targets --all-features",
    "rust:check:macos": "TAURI_CONFIG='{\"bundle\":{\"externalBin\":[],\"resources\":[]}}' rustup run 1.95.0 cargo check --locked --manifest-path app/src-tauri/Cargo.toml --target aarch64-apple-darwin --all-targets --all-features",
    "rust:clippy:macos": "TAURI_CONFIG='{\"bundle\":{\"externalBin\":[],\"resources\":[]}}' rustup run 1.95.0 cargo clippy --locked --manifest-path app/src-tauri/Cargo.toml --target aarch64-apple-darwin --all-targets --all-features -- -D warnings",
    "rust:test:macos": "TAURI_CONFIG='{\"bundle\":{\"externalBin\":[],\"resources\":[]}}' rustup run 1.95.0 cargo test --locked --manifest-path app/src-tauri/Cargo.toml --target aarch64-apple-darwin --all-targets --all-features",
    "verify:fast": "bun scripts/verify-fast.ts",
    "preview": "bun src/cli.ts preview",
    "drive": "bun scripts/drive.ts",
    "worktree:init": "bun scripts/worktree-init.ts",
    "setup:cli": "bun link",
    "state:init": "bun src/cli.ts state init",
    "project:init": "bun src/cli.ts project init",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/cli.ts state init",
    "roundtrip": "bun scripts/roundtrip.ts",
    "dials:generate": "bun scripts/dials-generate.ts",
    "edit": "bun scripts/edit.ts",
    "preview-op": "bun scripts/preview-op.ts",
    "undo": "bun scripts/undo.ts",
    "undo-op": "bun scripts/undo-op.ts",
    "diagnose": "bun scripts/diagnose.ts",
    "resolve": "bun scripts/resolve.ts",
    "refs": "bun scripts/refs.ts",
    "render": "bun scripts/render.ts",
    "still": "bun scripts/still.ts",
    "read-tools:artifact": "bun scripts/read-tools-artifact.ts",
    "lint:xml": "bun scripts/lint-xml.ts",
    "verify:corpus": "bun scripts/verify-corpus.ts",
    "verify:graphic": "bun scripts/verify-graphic-composite.ts",
    "verify:premult": "bun scripts/verify-premultiplied-alpha.ts",
    "verify:proxy": "bun scripts/verify-proxy.ts",
    "verify:backend-hmr": "bun scripts/verify-backend-hmr.ts",
    "demo:build": "bun corpus/demo/build-demo.ts",
    "graphic-overlay:build": "bun corpus/demo/build-graphic-overlay.ts",
    "verify:move5": "bun scripts/verify-move5.ts",
    "verify:live-overlay": "bun scripts/verify-live-overlay.ts",
    "verify:live-comp": "bun scripts/verify-live-comp.ts",
    "verify:live-hmr": "bun scripts/verify-live-hmr.ts",
    "verify:live-multi": "bun scripts/verify-live-multi.ts",
    "verify:live-error": "bun scripts/verify-live-error.ts",
    "verify:harness": "bun scripts/verify-harness.ts",
    "verify:all": "bun scripts/verify-harness.ts",
    "verify:ci-bootstrap": "bun scripts/ci/run-harness-profile.ts",
    "verify:fixture": "bun scripts/verify-fixture.ts",
    "verify:webview-policy": "bun scripts/verify-webview-policy.ts",
    "verify:tauri": "bun scripts/verify-tauri.ts",
    "verify:tauri-release-negative": "bun scripts/verify-tauri-instrumentation.ts",
    "verify:tauri-cleanup-failure": "bun scripts/verify-tauri.ts --simulate-session-failure",
    "verify:component": "bun scripts/verify-component.ts",
    "doctor:tauri-driver": "bun scripts/doctor-tauri-driver.ts",
    "doctor:macos-driver": "bun scripts/doctor-macos-driver.ts",
    "typecheck:macos-harness": "tsc -p tsconfig.macos-harness.json --noEmit",
    "verify:macos": "bun scripts/verify-macos.ts",
    "verify:macos-residual-negative": "bun scripts/verify-macos.ts --simulate-residual-dialog",
    "vm:macos": "bun scripts/vm/macos-vm.ts",
    "vm:macos:doctor": "bun scripts/vm/macos-vm.ts doctor",
    "vm:macos:configure": "bun scripts/vm/macos-vm.ts configure",
    "vm:macos:create-or-adopt": "bun scripts/vm/macos-vm.ts create-or-adopt",
    "vm:macos:configure-shares": "bun scripts/vm/macos-vm.ts configure-shares",
    "vm:macos:start": "bun scripts/vm/macos-vm.ts start",
    "vm:macos:setup-ssh": "bun scripts/vm/macos-vm.ts setup-ssh",
    "vm:macos:status": "bun scripts/vm/macos-vm.ts status",
    "vm:macos:bootstrap": "bun scripts/vm/macos-vm.ts bootstrap",
    "vm:macos:doctor-guest": "bun scripts/vm/macos-vm.ts doctor-guest",
    "vm:macos:verify-shares": "bun scripts/vm/macos-vm.ts verify-shares",
    "vm:macos:verify-native": "bun scripts/vm/macos-vm.ts verify-native",
    "vm:macos:collect-evidence": "bun scripts/vm/macos-vm.ts collect-evidence",
    "vm:macos:stop": "bun scripts/vm/macos-vm.ts stop",
    "harness:mutate": "bun scripts/harness/mutate.ts",
    "lsp": "bun src/bridge/lsp/server.ts",
    "mcp": "bun src/bridge/mcp/server.ts",
    "move2:e2e": "bun scripts/move2-e2e.ts",
    "verify:claude-code": "bun src/cli.ts doctor --host claude-code --surface mcp-lsp",
    "lint:comps": "bun scripts/comp-lint.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.9.3",
    "vscode-jsonrpc": "^9.0.0",
    "vscode-languageserver": "^10.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.3.14",
    "@wdio/appium-service": "9.29.1",
    "@wdio/cli": "9.29.1",
    "@wdio/local-runner": "9.29.1",
    "@wdio/mocha-framework": "9.29.1",
    "@wdio/native-utils": "2.5.0",
    "@wdio/spec-reporter": "9.29.1",
    "@wdio/tauri-service": "1.2.0",
    "appium": "3.5.2",
    "appium-mac2-driver": "4.0.3",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "webdriverio": "9.29.1",
    "yaml": "^2.9.0"
  }
}
