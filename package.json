{
  "name": "vean",
  "version": "0.0.0",
  "description": "The agent-native video editing core — a typed document, edit algebra, and diagnostics layer (a language server for video) on top of MLT.",
  "type": "module",
  "license": "AGPL-3.0-only",
  "private": true,
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "vean": "src/cli.ts",
    "vean-lsp": "src/bridge/lsp/server.ts",
    "vean-mcp": "src/bridge/mcp/server.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "doctor": "bun src/cli.ts doctor",
    "app:doctor": "bun scripts/app-doctor.ts",
    "app:build": "cd app && bun run tauri:build",
    "remotion:install": "cd remotion && bun install",
    "remotion:studio": "cd remotion && bun run studio",
    "viewer:install": "cd viewer && bun install",
    "viewer:dev": "cd viewer && bun run dev",
    "viewer:build": "cd viewer && bun run build",
    "preview": "bun src/cli.ts preview",
    "drive": "bun scripts/drive.ts",
    "worktree:init": "bun scripts/worktree-init.ts",
    "setup:cli": "bun link",
    "state:init": "bun src/cli.ts state init",
    "project:init": "bun src/cli.ts project init",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/cli.ts state init",
    "roundtrip": "bun scripts/roundtrip.ts",
    "dials:generate": "bun scripts/dials-generate.ts",
    "edit": "bun scripts/edit.ts",
    "preview-op": "bun scripts/preview-op.ts",
    "undo": "bun scripts/undo.ts",
    "undo-op": "bun scripts/undo-op.ts",
    "diagnose": "bun scripts/diagnose.ts",
    "resolve": "bun scripts/resolve.ts",
    "refs": "bun scripts/refs.ts",
    "render": "bun scripts/render.ts",
    "still": "bun scripts/still.ts",
    "read-tools:artifact": "bun scripts/read-tools-artifact.ts",
    "lint:xml": "bun scripts/lint-xml.ts",
    "verify:corpus": "bun scripts/verify-corpus.ts",
    "verify:graphic": "bun scripts/verify-graphic-composite.ts",
    "verify:premult": "bun scripts/verify-premultiplied-alpha.ts",
    "verify:proxy": "bun scripts/verify-proxy.ts",
    "verify:backend-hmr": "bun scripts/verify-backend-hmr.ts",
    "demo:build": "bun corpus/demo/build-demo.ts",
    "graphic-overlay:build": "bun corpus/demo/build-graphic-overlay.ts",
    "verify:move5": "bun scripts/verify-move5.ts",
    "verify:live-overlay": "bun scripts/verify-live-overlay.ts",
    "lsp": "bun src/bridge/lsp/server.ts",
    "mcp": "bun src/bridge/mcp/server.ts",
    "move2:e2e": "bun scripts/move2-e2e.ts",
    "verify:claude-code": "bun src/cli.ts doctor --host claude-code --surface mcp-lsp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.9.3",
    "vscode-jsonrpc": "^9.0.0",
    "vscode-languageserver": "^10.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
