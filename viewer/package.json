{
  "name": "vean-viewer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit && tsc -p tsconfig.browser.json --noEmit",
    "lint": "biome check .",
    "build": "vite build",
    "preview": "vite preview",
    "test:browser": "vitest run --config vitest.browser.config.ts"
  },
  "comment": "remotion/@remotion/player/react/react-dom are PINNED to exact versions that MUST match remotion/package.json — the live @remotion/player preview and the ProRes export render the same composition, so they must run the same Remotion/React version. `bun run doctor` asserts this parity; do not loosen to a range without keeping both files in lockstep.",
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/hanken-grotesk": "^5.2.8",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-slider": "^1.4.2",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-toggle-group": "^1.1.14",
    "@remotion/player": "4.0.484",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "mediabunny": "^1.49.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remotion": "4.0.484",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/browser-playwright": "4.1.10",
    "axe-core": "4.12.1",
    "playwright": "1.61.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.6.0",
    "vite": "^7.2.0",
    "vitest": "4.1.10",
    "vitest-browser-react": "2.2.0"
  }
}
