{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vean",
  "version": "0.0.0",
  "identifier": "studio.vean.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "vean",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "externalBin": [],
    "resources": ["sidecars/README.md"]
  }
}
