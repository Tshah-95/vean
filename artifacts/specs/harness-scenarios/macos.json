{
  "version": 1,
  "suite": "native-macos-shell-development",
  "maxInstances": 1,
  "authority": "Appium 3 / Mac2 / XCTest native accessibility tree",
  "runner_policy": {
    "class": "dedicated macOS GUI login session/runner",
    "shared_or_actively_used_desktop_allowed": false,
    "required_environment": {
      "VEAN_ALLOW_INTERACTIVE_MACOS_AUTOMATION": "1",
      "VEAN_MACOS_RUNNER_CLASS": "dedicated"
    },
    "default_failure": "E_INTERACTIVE_DESKTOP_OPT_IN",
    "preflight_boundary": "before fixture, build, Appium, WDA, Xcode, or Vean launch",
    "applies_to": ["H06 development Mac2 smoke", "H08R post-sign Mac2 smoke"]
  },
  "interaction_contract": {
    "version": "timeline-a11y-v1",
    "path": "artifacts/specs/timeline-keyboard-accessibility-contract-v1.md",
    "sha256": "90e92872cc4df0dc12705ee560d2e2e5e3a916210c2a2eebb73e2cbd15c9a6d1",
    "scope": "native shell focus and accessibility only; detailed timeline semantics remain H03 authority"
  },
  "excluded_authority": [
    "detailed web editor DOM",
    "screen coordinates",
    "screenshots as truth",
    "installed release package"
  ],
  "scenarios": [
    {
      "id": "macos-shell-role-name-focus",
      "truth": ["native window role", "accessible name", "focused state"]
    },
    {
      "id": "macos-open-project-cancel-focus-restore",
      "truth": [
        "File menu accessible name",
        "Open Project Folder panel",
        "Cancel",
        "focus restoration"
      ]
    },
    {
      "id": "macos-open-project-real-folder",
      "truth": [
        "semantic file-panel controls",
        "exact selected fixture folder",
        "replacement sidecar command"
      ]
    },
    {
      "id": "macos-window-close-reopen-classification",
      "truth": [
        "native close",
        "zero remaining windows",
        "current product reopen support explicitly false"
      ]
    },
    {
      "id": "macos-native-quit",
      "truth": ["native app menu", "semantic Quit item", "post-session cleanup"]
    }
  ],
  "negative_controls": [
    {
      "id": "nc-native-macos-shell",
      "mutation": "replace the real Rust File menu accessibility label",
      "required_failure": "canonical Mac2 semantic locator cannot find Open Project Folder…"
    },
    {
      "id": "nc-native-macos-residual-dialog",
      "mutation": "leave the real Open Project Folder panel unresolved",
      "required_failure": "teardown detects residual native dialog before forced cleanup"
    }
  ]
}
