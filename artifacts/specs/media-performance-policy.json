{
  "schema_version": "1.0.0",
  "policy_id": "vean-media-performance-policy-v1",
  "status": "draft",
  "implementation_base_sha": "b416c8a5f26730a838a3e847aaab44e3e4772508",
  "approved_by": null,
  "approved_at": null,
  "baseline_run_ids": [],
  "baseline_command": "bun run verify:media --suite baseline --no-accept",
  "acceptance_command": "bun run verify:media --suite performance --policy artifacts/specs/media-performance-policy.json",
  "sampling": {
    "warmup_runs": 3,
    "measured_fresh_process_runs": 15,
    "steady_state_composite_samples_per_run": 300,
    "percentile_method": "nearest-rank",
    "reported": [
      "raw_workload_events",
      "raw_timestamps",
      "raw_process_rss_bytes",
      "raw_cache_bytes",
      "raw_resource_events",
      "raw_failure_events",
      "independently_derived_p50_p95_max_and_slope"
    ],
    "workloads": [
      "cold-proxy-build",
      "warm-proxy-cache",
      "seek-to-valid-frame",
      "playback-audio-video-skew",
      "queue-drain-after-scrub",
      "project-open-to-valid-frame",
      "teardown",
      "context-recovery-to-valid-frame",
      "process-rss-and-cache-memory",
      "crashes-stalls-black-frames",
      "compositor-microbenchmark"
    ]
  },
  "required_environment_identity": [
    "cpu_model_and_count",
    "ram",
    "vm_or_physical_model",
    "os_build",
    "app_browser_webkit_binary_hashes",
    "gpu_backend",
    "display_scale",
    "instrumentation_overhead",
    "thermal_state_if_available"
  ],
  "functional_caps": {
    "decoder_workers_max": 4,
    "in_flight_decodes_max": 8,
    "steady_queue_max": 8,
    "queue_must_drain_to_zero_after_scrub": true,
    "cache_resident_bytes_max": 524288000,
    "owned_handle_open_close_balance_required": true,
    "crashes_unhandled_errors_black_frames_stalls_max": 0,
    "context_restore_requires_content_valid_frame": true
  },
  "proposed_user_visible_budgets": {
    "approval_required": true,
    "chrome": {
      "composite_p95_ms": 26.7,
      "composite_max_ms": 66.7,
      "cold_proxy_build_p95_ms": 5000,
      "warm_proxy_cache_p95_ms": 250,
      "warm_seek_valid_frame_p95_ms": 100,
      "playhead_audio_skew_p95_frames": 1,
      "queue_drain_after_scrub_ms": 500,
      "context_loss_valid_frame_ms": 1000,
      "warm_project_open_valid_frame_ms": 2000,
      "teardown_p95_ms": 500,
      "post_warm_memory_slope_mib_per_min": 1
    },
    "release_wkwebview": {
      "composite_p95_ms": 26.7,
      "composite_max_ms": 66.7,
      "cold_proxy_build_p95_ms": 5000,
      "warm_proxy_cache_p95_ms": 250,
      "warm_seek_valid_frame_p95_ms": 150,
      "playhead_audio_skew_p95_frames": 1,
      "queue_drain_after_scrub_ms": 750,
      "context_loss_valid_frame_ms": 1500,
      "warm_project_open_valid_frame_ms": 3000,
      "teardown_p95_ms": 750,
      "post_warm_memory_slope_mib_per_min": 1
    },
    "absolute_process_memory_ceiling_mib": null
  },
  "rules": {
    "browser_ci_and_release_package_are_separate_distributions": true,
    "all_declared_workloads_require_hashed_raw_artifacts": true,
    "domain_verifier_recomputes_summaries_caps_and_budgets": true,
    "producer_authored_pass_booleans_are_forbidden": true,
    "compositor_timing_is_a_named_microbenchmark_not_user_visible_performance": true,
    "automatic_baseline_multiplier_forbidden": true,
    "acceptance_requires_approved_policy_and_exact_environment": true,
    "post_dated_or_missing_baseline_rejected": true
  },
  "negative_controls": [
    "missing-imagebitmap-close",
    "missing-worker-decoder-audio-gl-disposal",
    "unrestored-webgl-context-loss",
    "injected-long-task",
    "unbounded-queue-or-cache-growth",
    "injected-playback-skew",
    "never-draining-queue",
    "context-restored-with-blank-frame",
    "inline-summary-vs-artifact-mismatch",
    "unapproved-policy",
    "missing-required-runtime-cell"
  ]
}
